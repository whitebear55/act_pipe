<mujoco model="left leap hand scene rotation">
  <include file="left_hand_fixed.xml"/>

  <statistic center="-0.07 0.1 0.12" extent=".3"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="45" elevation="-50"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
    markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <texture type="2d" name="manip_checker" builtin="checker" rgb1="0.9 0.9 0.9" rgb2="0.2 0.2 0.2" width="256" height="256"/>
    <material name="manip_textured" texture="manip_checker" texrepeat="12 12" rgba="0.9 0.4 0.1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <camera name="perspective" pos="0.4 -0.4 0.4" xyaxes="1 1 0 -1 1 3" mode="trackcom"/>
    <camera name="side" pos="0 -0.6 0.4" xyaxes="1 0 0 0 1 3" mode="trackcom"/>
    <camera name="top" pos="0 0 0.6" xyaxes="0 1 0 -1 0 0" mode="trackcom"/>
    <camera name="front" pos="0.6 0 0.4" xyaxes="0 1 0 -1 0 3" mode="trackcom"/>
  </worldbody>

  <sensor>
    <framepos name="th_tip_framepos" objtype="site" objname="th_tip"/>
    <framequat name="th_tip_framequat" objtype="site" objname="th_tip"/>
    <framelinvel name="th_tip_framelinvel" objtype="site" objname="th_tip"/>
    <frameangvel name="th_tip_frameangvel" objtype="site" objname="th_tip"/>
    <force name="th_tip_force" site="th_tip"/>
    <torque name="th_tip_torque" site="th_tip"/>

    <framepos name="if_tip_framepos" objtype="site" objname="if_tip"/>
    <framequat name="if_tip_framequat" objtype="site" objname="if_tip"/>
    <framelinvel name="if_tip_framelinvel" objtype="site" objname="if_tip"/>
    <frameangvel name="if_tip_frameangvel" objtype="site" objname="if_tip"/>
    <force name="if_tip_force" site="if_tip"/>
    <torque name="if_tip_torque" site="if_tip"/>

    <framepos name="mf_tip_framepos" objtype="site" objname="mf_tip"/>
    <framequat name="mf_tip_framequat" objtype="site" objname="mf_tip"/>
    <framelinvel name="mf_tip_framelinvel" objtype="site" objname="mf_tip"/>
    <frameangvel name="mf_tip_frameangvel" objtype="site" objname="mf_tip"/>
    <force name="mf_tip_force" site="mf_tip"/>
    <torque name="mf_tip_torque" site="mf_tip"/>
  </sensor>
</mujoco>
